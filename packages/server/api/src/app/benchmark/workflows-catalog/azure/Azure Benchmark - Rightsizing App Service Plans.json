                                  "code": "export const code = async (inputs) => {\n  const series = Array.isArray(inputs?.timeseries) ? inputs.timeseries : [];\n  let globalMax = 0;\n\n  for (const s of series) {\n    const points = Array.isArray(s?.data) ? s.data : [];\n    for (const p of points) {\n      if (p?.maximum === undefined || p.maximum === null) continue;\n\n      const val = typeof p.maximum === 'string' ? Number(p.maximum) : p.maximum;\n      if (Number.isFinite(val) && val > globalMax) {\n        globalMax = val;\n      }\n    }\n  }\n\n  return globalMax;\n};\n",
