                        "sourceCode": {
                          "code": "export const code = async (inputs) => {\n  const normalize = (value) =>\n    String(value || \"\")\n      .toLowerCase()\n      .replace(/\\s+/g, \"\");\n\n  const parseItem = (item) => {\n    if (typeof item !== \"string\") return item;\n\n    try {\n      return JSON.parse(item);\n    } catch {\n      return null;\n    }\n  };\n\n  const itemsRaw = inputs?.items;\n\n  const items = Array.isArray(itemsRaw)\n    ? itemsRaw\n    : itemsRaw\n      ? [itemsRaw]\n      : [];\n\n  const region = normalize(inputs?.region);\n\n  return items\n    .map(parseItem)\n    .filter(Boolean)\n    .filter((item) => normalize(item?.location) === region);\n};",
