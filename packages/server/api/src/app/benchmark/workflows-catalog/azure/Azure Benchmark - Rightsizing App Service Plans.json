                                  },
                                  "sourceCode": {
                                    "code": "export const code = async (inputs) => {\n  const normalizeMetricName = (value) =>\n    String(value || \"\")\n      .toLowerCase()\n      .replace(/\\s+/g, \"\");\n\n  const getMaxFromTimeseries = (timeseries) => {\n    const series = Array.isArray(timeseries) ? timeseries : [];\n    let max = 0;\n\n    for (const s of series) {\n      const points = Array.isArray(s?.data) ? s.data : [];\n\n      for (const p of points) {\n        if (p?.maximum === undefined || p.maximum === null) continue;\n\n        const val = typeof p.maximum === \"string\" ? Number(p.maximum) : p.maximum;\n\n        if (Number.isFinite(val) && val > max) {\n          max = val;\n        }\n      }\n    }\n\n    return max;\n  };\n\n  const rawMetrics = inputs?.metrics;\n\n  const metrics = Array.isArray(rawMetrics)\n    ? rawMetrics\n    : Array.isArray(rawMetrics?.value)\n      ? rawMetrics.value\n      : rawMetrics\n        ? [rawMetrics]\n        : [];\n\n  const result = {\n    CpuPercentage: 0,\n    MemoryPercentage: 0,\n  };\n\n  for (const metric of metrics) {\n    const metricName = normalizeMetricName(\n      metric?.name?.value ||\n      metric?.name?.localizedValue ||\n      metric?.name ||\n      metric?.id\n    );\n\n    const max = getMaxFromTimeseries(metric?.timeseries);\n\n    if (metricName.includes(\"cpupercentage\")) {\n      result.CpuPercentage = max;\n    }\n\n    if (metricName.includes(\"memorypercentage\")) {\n      result.MemoryPercentage = max;\n    }\n  }\n\n  return result;\n};",
                                    "packageJson": "{}"
                                  },
