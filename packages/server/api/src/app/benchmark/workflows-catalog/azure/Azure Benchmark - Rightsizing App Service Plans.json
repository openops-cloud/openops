                                        },
                                        "sourceCode": {
                                          "code": "export const code = async (inputs) => {\n  const appServicePlan = inputs?.reserved?.item || inputs?.reserved || {};\n\n  const sku = inputs?.sku || appServicePlan?.sku || {};\n  const family = String(sku.family || \"\").toUpperCase();\n  const currentName = String(sku.name || sku.size || \"\").toUpperCase();\n\n  if (!family || !currentName) {\n    return { error: \"sku.family and sku.name/sku.size are required.\" };\n  }\n\n  const norm = (s) => String(s || \"\").toUpperCase().replace(/\\s+/g, \"\");\n\n  const parseSizeNum = (name) => {\n    const n = norm(name);\n\n    let m = n.match(/^[A-Z]+(\\d+)M?V\\d+$/); // P2mv3 / P2v3\n    if (m) return parseInt(m[1], 10);\n\n    m = n.match(/^[A-Z]+(\\d+)$/); // S1 / B3 / I4\n    if (m) return parseInt(m[1], 10);\n\n    m = n.match(/^([A-Z]+)(\\d+)/); // \"S1 App\"\n    if (m) return parseInt(m[2], 10);\n\n    return NaN;\n  };\n\n  const isHourlyConsumptionAppService = (it) => {\n    if (!it) return false;\n    if (it.serviceName !== \"Azure App Service\") return false;\n    if (String(it.type || \"\").toLowerCase() !== \"consumption\") return false;\n    if (!/hour/i.test(it.unitOfMeasure || \"\")) return false;\n    return true;\n  };\n\n  const kind = String(appServicePlan?.kind || \"\").toLowerCase();\n\n  const reserved =\n    kind.includes(\"linux\") ? true :\n    kind ? false :\n    null;\n\n  const osLabel = reserved == null ? null : reserved ? \"linux\" : \"windows\";\n\n  const matchesReserved = (it) => {\n    if (reserved == null) return true;\n\n    const blob = `${it?.productName || \"\"} ${it?.armSkuName || \"\"} ${it?.skuName || \"\"} ${it?.meterName || \"\"}`;\n    const isLinux = /linux/i.test(blob);\n\n    return reserved ? isLinux : !isLinux;\n  };\n\n  const currentSize = parseSizeNum(currentName);\n\n  if (!Number.isFinite(currentSize)) {\n    return { error: `Could not parse size from current sku \"${currentName}\".` };\n  }\n\n  const items = Array.isArray(inputs?.items) ? inputs.items : [];\n\n  const candidateNames = items\n    .filter((it) => {\n      if (!isHourlyConsumptionAppService(it)) return false;\n      if (!matchesReserved(it)) return false;\n\n      const skuN = norm(it?.skuName);\n      const meterN = norm(it?.meterName);\n\n      return skuN.startsWith(family) || meterN.startsWith(family);\n    })\n    .map((it) => it.skuName || it.meterName)\n    .filter(Boolean);\n\n  const uniq = new Map();\n\n  for (const name of candidateNames) {\n    const key = norm(name);\n    if (!uniq.has(key)) uniq.set(key, name);\n  }\n\n  const sameFamily = Array.from(uniq.values())\n    .map((raw) => ({ raw, size: parseSizeNum(raw) }))\n    .filter((x) => Number.isFinite(x.size));\n\n  const lowerOptions = sameFamily\n    .filter((x) => x.size < currentSize)\n    .sort((a, b) => b.size - a.size)\n    .map((x) => x.raw);\n\n  const proposedSku = lowerOptions[0] || null;\n\n  const chooseBestPriceRow = (rows) => {\n    if (!rows.length) return null;\n\n    rows.sort((a, b) => {\n      const priA = a.isPrimaryMeterRegion ? 1 : 0;\n      const priB = b.isPrimaryMeterRegion ? 1 : 0;\n\n      if (priB !== priA) return priB - priA;\n\n      return (a.retailPrice ?? a.unitPrice ?? Infinity) - (b.retailPrice ?? b.unitPrice ?? Infinity);\n    });\n\n    return rows[0];\n  };\n\n  const getHourlyPriceForName = (targetName) => {\n    if (!targetName || !items.length) return null;\n\n    const t = norm(targetName);\n\n    const matched = items.filter((it) => {\n      if (!isHourlyConsumptionAppService(it)) return false;\n      if (!matchesReserved(it)) return false;\n\n      const skuN = norm(it?.skuName);\n      const meterN = norm(it?.meterName);\n\n      const skuHit = skuN === t || skuN.startsWith(t);\n      const meterHit = meterN === t || meterN.startsWith(t);\n      const famHit = skuN.startsWith(family) || meterN.startsWith(family);\n\n      return famHit && (skuHit || meterHit);\n    });\n\n    const row = chooseBestPriceRow(matched);\n\n    if (!row) return null;\n\n    return {\n      hourlyPrice: Number(row.retailPrice ?? row.unitPrice ?? NaN),\n      currency: row.currencyCode || \"USD\",\n      matchedSkuName: row.skuName,\n      matchedMeterName: row.meterName,\n      productName: row.productName,\n      armSkuName: row.armSkuName,\n    };\n  };\n\n  const currentPriceInfo = getHourlyPriceForName(currentName);\n  const proposedPriceInfo = proposedSku ? getHourlyPriceForName(proposedSku) : null;\n\n  const hoursInMonth = 730;\n\n  const canCalc =\n    currentPriceInfo?.hourlyPrice != null &&\n    proposedPriceInfo?.hourlyPrice != null &&\n    Number.isFinite(currentPriceInfo.hourlyPrice) &&\n    Number.isFinite(proposedPriceInfo.hourlyPrice);\n\n  const hourlyDelta = canCalc\n    ? currentPriceInfo.hourlyPrice - proposedPriceInfo.hourlyPrice\n    : null;\n\n  const monthlySavings = canCalc ? +(hourlyDelta * hoursInMonth).toFixed(2) : null;\n\n  return {\n    family,\n    reserved,\n    os: osLabel,\n    current: {\n      name: currentName,\n      size: currentSize,\n      hourlyPrice: currentPriceInfo?.hourlyPrice ?? null,\n      currency: currentPriceInfo?.currency ?? null,\n      matched: {\n        skuName: currentPriceInfo?.matchedSkuName ?? null,\n        meterName: currentPriceInfo?.matchedMeterName ?? null,\n        productName: currentPriceInfo?.productName ?? null,\n        armSkuName: currentPriceInfo?.armSkuName ?? null,\n      },\n    },\n    proposed: proposedSku\n      ? {\n          name: proposedSku,\n          size: parseSizeNum(proposedSku),\n          hourlyPrice: proposedPriceInfo?.hourlyPrice ?? null,\n          currency: proposedPriceInfo?.currency ?? currentPriceInfo?.currency ?? null,\n          matched: {\n            skuName: proposedPriceInfo?.matchedSkuName ?? null,\n            meterName: proposedPriceInfo?.matchedMeterName ?? null,\n            productName: proposedPriceInfo?.productName ?? null,\n            armSkuName: proposedPriceInfo?.armSkuName ?? null,\n          },\n        }\n      : null,\n    lowerExists: !!proposedSku,\n    lowerOptions,\n    considered: sameFamily.map((x) => x.raw),\n    pricingBasis: {\n      itemsProvided: !!items.length,\n      filters: {\n        serviceName: \"Azure App Service\",\n        type: \"Consumption\",\n        unitOfMeasure: \"Hour\",\n        reserved: reserved === null ? \"not enforced\" : reserved,\n        os: osLabel || \"not enforced\",\n        family,\n      },\n      note: \"Only data present in inputs.items is considered. No SKU fallback.\",\n    },\n    economics: canCalc\n      ? {\n          hoursInMonth,\n          hourlyDelta: +hourlyDelta.toFixed(6),\n          monthlySavings,\n          note:\n            \"monthlySavings = (currentHourly - proposedHourly) * 730; negative means proposed is more expensive\",\n        }\n      : {\n          hoursInMonth,\n          message:\n            \"Could not compute savings (missing or unmatched hourly prices for current/proposed) or no lower-sized SKU found.\",\n        },\n  };\n};",
                                          "packageJson": "{}"
