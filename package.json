{
  "name": "openops",
  "version": "0.100.0",
  "rcVersion": "0.100.0",
  "scripts": {
    "setup:husky": "husky || true",
    "setup:env": "[ ! -e .env ] && cp -v .env.template .env || :",
    "prepare": "npm run setup:env && npm run setup:husky",
    "serve:frontend": "nx serve react-ui",
    "build:frontend": "nx build react-ui",
    "serve:worker": "cross-env OPS_CONTAINER_TYPE=WORKER PORT=3010 nx run server-api:serve:development",
    "build:server-worker": "npx nx run server-worker:build",
    "serve:app": "cross-env OPS_CONTAINER_TYPE=APP nx run server-api:serve:app",
    "license-check": "npx generate-license-file --overwrite --config ./tools/licenses/.generatelicensefile.json",
    "watch:engine": "nx run engine:build:watch",
    "dev": "npm run build:server-worker && npm run build:blocks && npm run link:packages && cross-env-shell FORCE_COLOR=true concurrently -n \"GUI,WORKER,ENG,APP\" -c \"bgBlue.bold,bgMagenta.bold,bgYellow.bold,bgGreen.bold\" \"npm:serve:frontend\" \"npm:serve:worker\" \"npm:watch:engine\" \"npm:serve:app\"",
    "start": "npm i --no-save && docker compose up -d --wait && npm run dev",
    "cli": "npx ts-node packages/cli/src/index.ts",
    "create-block": "npx ts-node packages/cli/src/index.ts blocks create",
    "create-action": "npx ts-node packages/cli/src/index.ts actions create",
    "create-trigger": "npx ts-node packages/cli/src/index.ts triggers create",
    "sync-blocks": "npx ts-node packages/cli/src/index.ts blocks sync",
    "publish-block": "npx ts-node tools/scripts/blocks/publish-block.ts",
    "pull-i18n": "crowdin pull --config crowdin.yml",
    "push-i18n": "crowdin upload sources",
    "i18n:extract": "i18next --config packages/react-ui/i18next-parser.config.js && jq 'to_entries | map({(.key): .key}) | add' packages/react-ui/public/locales/en/translation.json > packages/react-ui/public/locales/en/translation.tmp.json && mv packages/react-ui/public/locales/en/translation.tmp.json packages/react-ui/public/locales/en/translation.json",
    "storybook": "nx run ui-components:storybook",
    "build-storybook": "cd packages/ui-components && storybook build",
    "chromatic": "npx chromatic --",
    "build:blocks": "npx nx run-many -t build -p blocks-*",
    "link:packages": "./tools/link-packages.sh"
  },
  "private": true,
